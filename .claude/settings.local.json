{
  "permissions": {
    "allow": [
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/login)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/dashboard)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000/pay/test123)",
      "Bash(curl -s http://localhost:3000/login)",
      "Bash(curl -s -o /dev/null -w \"dashboard: %{http_code}\\\\n\" -L http://localhost:3000/dashboard)",
      "Bash(curl -s -o /dev/null -w \"login: %{http_code}\\\\n\" http://localhost:3001/login)",
      "Bash(curl -s -o /dev/null -w \"dashboard \\(sans auth\\): %{http_code}\\\\n\" http://localhost:3001/dashboard)",
      "Bash(curl -s -o /dev/null -w \"pay page: %{http_code}\\\\n\" http://localhost:3001/pay/test123)",
      "Bash(curl *)",
      "Bash(python3 -c ' *)",
      "Bash(pkill -9 -f \"next\")",
      "Bash(lsof -ti:3000)",
      "Bash(awk '{print $2}')",
      "Bash(xargs kill)",
      "Bash(npx tsc *)",
      "Bash(node_modules/.bin/tsc --noEmit)"
    ]
  }
}
